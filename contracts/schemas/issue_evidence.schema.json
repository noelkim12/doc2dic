{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doc2dic.local/schemas/issue_evidence.schema.json",
  "title": "IssueEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "sourceDocumentId", "quote", "confidence"],
  "properties": {
    "id": { "type": "string", "pattern": "^evidence_[A-Za-z0-9_-]+$" },
    "kind": { "type": "string", "enum": ["quote", "occurrence", "graph_relation", "llm_rationale"] },
    "sourceDocumentId": { "type": "string", "pattern": "^doc_[A-Za-z0-9_-]+$" },
    "chunkId": { "type": ["string", "null"], "pattern": "^chunk_[A-Za-z0-9_-]+$" },
    "quote": { "type": "string", "minLength": 1, "maxLength": 600 },
    "contextBefore": { "type": "string", "maxLength": 240 },
    "contextAfter": { "type": "string", "maxLength": 240 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
